    'bg':     '#0B0F1A',
    'bg2':    '#111827',
    'gold':   '#D6A85A',
    'parch':  '#EDE4D4',
    'muted':  '#9A8D7B',
    'teal':   '#8EC3B8',
    'red':    '#B97A6F',
    'border': '#2A3042',
}

STYLESHEET = f"""
