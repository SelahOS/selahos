def _user_and_home():
    user = os.environ.get('SUDO_USER') or os.environ.get('USER') or 'dbnoble'
    home = Path(f'/home/{user}') if user != 'root' else Path('/root')
    return user, home


def _wine_env(user, home):
    return {
        **os.environ,
        'HOME': str(home),
        'USER': user,
        'WINEPREFIX': str(home / '.wine'),
        'WINEARCH': 'win64',
        'DISPLAY': os.environ.get('DISPLAY', ':0'),
    }


def _uid_of(user):
    try:
        import pwd
        return pwd.getpwnam(user).pw_uid
    except Exception:
        return 1000


def _divider():
    div = QFrame()
    div.setFixedHeight(1)
    div.setStyleSheet(f"background: {COLORS['border']};")
    return div


def _log_append(log_widget, text):
    log_widget.append(text)
    log_widget.verticalScrollBar().setValue(log_widget.verticalScrollBar().maximum())


# ─────────────────────────────────────────────────────────
# Tab 1 — Installed Apps
# ─────────────────────────────────────────────────────────

class AppRow(QFrame):
    launch_requested   = pyqtSignal(str, str)
    uninstall_requested = pyqtSignal(str, str)

    def __init__(self, name, exe_path):
        super().__init__()
        self.name = name
        self.exe_path = exe_path
        self.setStyleSheet(f"QFrame {{ background: {COLORS['bg3']}; border: 1px solid {COLORS['border']}; border-radius: 4px; }}")
        layout = QHBoxLayout(self)
        layout.setContentsMargins(16, 10, 16, 10)

        name_lbl = QLabel(name)
        name_lbl.setFont(QFont('Noto Sans', 13))
        name_lbl.setMinimumWidth(180)
        layout.addWidget(name_lbl)

        path_lbl = QLabel(exe_path)
        path_lbl.setFont(QFont('JetBrains Mono', 11))
        path_lbl.setStyleSheet(f"color: {COLORS['muted']};")
        path_lbl.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Preferred)
        layout.addWidget(path_lbl)

        launch_btn = QPushButton("Launch")
        launch_btn.setFixedWidth(80)
        launch_btn.clicked.connect(lambda: self.launch_requested.emit(self.name, self.exe_path))
        layout.addWidget(launch_btn)

        remove_btn = QPushButton("Remove")
        remove_btn.setObjectName("danger")
        remove_btn.setFixedWidth(80)
        remove_btn.clicked.connect(lambda: self.uninstall_requested.emit(self.name, self.exe_path))
        layout.addWidget(remove_btn)


class AppsTab(QWidget):
    def __init__(self):
        super().__init__()
        self.user, self.home = _user_and_home()
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(24, 20, 24, 20)
        layout.setSpacing(12)

        header = QHBoxLayout()
        title = QLabel("Installed Windows Apps")
        title.setFont(QFont('Noto Sans', 15, QFont.Weight.Bold))
        title.setStyleSheet(f"color: {COLORS['gold']};")
        header.addWidget(title)
        header.addStretch()

        refresh_btn = QPushButton("Refresh")
        refresh_btn.setObjectName("secondary")
        refresh_btn.clicked.connect(self._scan)
        header.addWidget(refresh_btn)

        add_btn = QPushButton("+ Add App")
        add_btn.clicked.connect(self._add_app)
        header.addWidget(add_btn)
        layout.addLayout(header)

        self.no_prefix_lbl = QLabel(
            "Wine prefix not found. Install SelahBridge first, or initialize it in Wine Settings."
        )
        self.no_prefix_lbl.setStyleSheet(f"color: {COLORS['red']}; padding: 12px;")
        self.no_prefix_lbl.setWordWrap(True)
        self.no_prefix_lbl.hide()
        layout.addWidget(self.no_prefix_lbl)

        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setStyleSheet(f"QScrollArea {{ background: {COLORS['bg2']}; border: 1px solid {COLORS['border']}; border-radius: 4px; }}")

        self.apps_container = QWidget()
        self.apps_container.setStyleSheet(f"background: {COLORS['bg2']};")
        self.apps_layout = QVBoxLayout(self.apps_container)
        self.apps_layout.setContentsMargins(8, 8, 8, 8)
        self.apps_layout.setSpacing(4)
        self.apps_layout.addStretch()
        scroll.setWidget(self.apps_container)
        layout.addWidget(scroll)

        self.log = QTextEdit()
        self.log.setReadOnly(True)
        self.log.setFixedHeight(72)
        self.log.setPlaceholderText("Action log...")
        layout.addWidget(self.log)

        self._scan()

    def _scan(self):
        while self.apps_layout.count() > 1:
            item = self.apps_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        drive_c = self.home / '.wine' / 'drive_c'
        if not drive_c.exists():
            self.no_prefix_lbl.show()
            return
        self.no_prefix_lbl.hide()

        found = []
        for prog_dir in ['Program Files', 'Program Files (x86)']:
            base = drive_c / prog_dir
            if not base.exists():
                continue
            for app_dir in sorted(base.iterdir()):
                if not app_dir.is_dir():
                    continue
                exes = list(app_dir.glob('*.exe')) or list(app_dir.rglob('*.exe'))
                if exes:
                    found.append((app_dir.name, str(exes[0])))

        if not found:
            lbl = QLabel("No Windows applications found.")
            lbl.setStyleSheet(f"color: {COLORS['muted']}; padding: 20px;")
            lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
            self.apps_layout.insertWidget(0, lbl)
            return

        for name, exe_path in found:
            row = AppRow(name, exe_path)
            row.launch_requested.connect(self._launch)
            row.uninstall_requested.connect(self._remove)
            self.apps_layout.insertWidget(self.apps_layout.count() - 1, row)

    def _launch(self, name, exe_path):
        _log_append(self.log, f"Launching {name}...")
        subprocess.Popen(
            ['sudo', '-u', self.user, 'wine', exe_path],
            env=_wine_env(self.user, self.home)
        )
        _log_append(self.log, f"✓ {name} launched")

    def _remove(self, name, exe_path):
        if QMessageBox.question(
            self, "Remove App",
            f"Remove {name}?\nThis deletes the app directory.",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No
        ) != QMessageBox.StandardButton.Yes:
            return
        try:
            shutil.rmtree(str(Path(exe_path).parent))
            _log_append(self.log, f"✓ {name} removed")
            self._scan()
        except Exception as e:
            _log_append(self.log, f"✗ {e}")

    def _add_app(self):
        default_dir = str(self.home / '.wine' / 'drive_c')
        path, _ = QFileDialog.getOpenFileName(
            self, "Select Windows Executable", default_dir, "Executables (*.exe)"
        )
        if not path:
            return
        _log_append(self.log, f"Launching {Path(path).stem}...")
        subprocess.Popen(
            ['sudo', '-u', self.user, 'wine', path],
            env=_wine_env(self.user, self.home)
        )
        self._scan()


